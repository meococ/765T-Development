{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "765T Assistant Memory Architecture",
  "_version": "1.0.0",
  "_updated": "2026-03-22",
  "_description": "Canonical memory posture for the repo-neutral assistant platform.",
  "durableTruth": {
    "eventStore": "SQLite",
    "lexicalFallback": "SQLite projection/search",
    "semanticLayer": "Qdrant",
    "degradeMode": "lexical_only"
  },
  "namespaces": [
    "atlas-native-commands",
    "atlas-custom-tools",
    "atlas-curated-scripts",
    "playbooks-policies",
    "project-runtime-memory",
    "evidence-lessons"
  ],
  "rules": {
    "upsertOrder": ["sqlite", "qdrant"],
    "semanticOptional": true,
    "providerNeutral": true
  }
}
