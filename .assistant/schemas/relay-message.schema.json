{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Relay Message",
  "description": "Structured message for Codex ↔ Claude dual-agent relay protocol. Agent-agnostic: works for any pair of AI agents communicating via shared filesystem.",
  "type": "object",
  "required": ["messageId", "timestamp", "from", "to", "role", "type", "content"],
  "properties": {
    "messageId": {
      "type": "string",
      "description": "UUID v4 identifying this message"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp"
    },
    "from": {
      "type": "string",
      "enum": ["claude", "codex", "human"],
      "description": "Sender agent identity"
    },
    "to": {
      "type": "string",
      "enum": ["claude", "codex", "human"],
      "description": "Target agent identity"
    },
    "role": {
      "type": "string",
      "enum": ["reviewer", "planner", "debugger", "executor", "critic", "architect"],
      "description": "Role assigned to the target agent for this message"
    },
    "type": {
      "type": "string",
      "enum": ["task", "review", "plan", "critique", "decision", "handoff", "status"],
      "description": "Message type"
    },
    "sessionId": {
      "type": "string",
      "description": "Groups related messages into a conversation thread"
    },
    "parentMessageId": {
      "type": "string",
      "description": "messageId of the message being replied to"
    },
    "taskContext": {
      "type": "string",
      "description": "Original task description from the user"
    },
    "revitContextPath": {
      "type": "string",
      "description": "Relative path to revit-task-context JSON snapshot"
    },
    "content": {
      "type": "object",
      "description": "Structured message payload",
      "properties": {
        "summary": {
          "type": "string",
          "description": "Brief summary of findings/decisions/plan"
        },
        "findings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Key findings or observations"
        },
        "toolPlan": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step": { "type": "integer" },
              "tool": { "type": "string" },
              "purpose": { "type": "string" },
              "risk": { "type": "string" },
              "payload": { "type": "object" }
            },
            "required": ["step", "tool", "purpose"]
          },
          "description": "Ordered tool execution plan"
        },
        "codeChanges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "file": { "type": "string" },
              "action": { "type": "string", "enum": ["create", "modify", "delete"] },
              "description": { "type": "string" },
              "diff": { "type": "string" }
            },
            "required": ["file", "action", "description"]
          },
          "description": "Code changes made or proposed"
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Identified risks or concerns"
        },
        "questions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Questions for the other agent or human"
        },
        "decisions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Decisions made in this turn"
        },
        "nextActions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Recommended next steps"
        }
      }
    },
    "attachments": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Relative paths to attached files (diffs, snapshots, logs)"
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata",
      "properties": {
        "model": { "type": "string", "description": "AI model used (e.g., opus-4.6, gpt-5.4)" },
        "durationMs": { "type": "integer", "description": "Processing time in milliseconds" },
        "tokenCount": { "type": "integer", "description": "Approximate token usage" }
      }
    }
  }
}
