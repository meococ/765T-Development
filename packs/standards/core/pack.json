    {
      "ExportKind": "standard",
      "RelativePath": "assets/title_blocks.json",
      "ExportId": "title_blocks"
    },
    {
      "ExportKind": "standard",
      "RelativePath": "assets/filters.json",
      "ExportId": "filters"
    },
    {
      "ExportKind": "standard",
      "RelativePath": "assets/scales.json",
      "ExportId": "scales"
    },
    {
      "ExportKind": "standard",
      "RelativePath": "assets/parameters.json",
      "ExportId": "parameters"
    },
    {
      "ExportKind": "standard",
      "RelativePath": "assets/qc_rules.json",
      "ExportId": "qc_rules"
    }
  ],
  "EnabledByDefault": true
}
