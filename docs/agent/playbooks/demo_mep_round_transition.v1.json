{
  "PlaybookId": "demo_mep_round_transition",
  "Version": "1.0",
  "Description": "Showcase: Tao family MEP Round Duct Transition (Reducer) hoan chinh voi 18+ tool calls, su dung 8 NEW tools.",
  "Lane": "B",
  "RequiredContext": "family_document",
  "FamilyTemplate": "Metric Duct Fitting hoac Generic Model",
  "DecisionGate": {
    "Use_When": [
      "demo / showcase family authoring capability",
      "tao family duct transition / reducer",
      "can vi du toan dien ve family authoring flow"
    ],
    "Dont_Use_When": [
      "family template khong phai MEP hoac Generic",
      "chi can family don gian (dung family_create_simple)"
    ]
  },
  "Steps": [
    {
      "StepNum": 1,
      "StepName": "set_category",
      "Tool": "family.set_category_safe",
      "Purpose": "Dat category la Duct Fittings.",
      "Payload": { "CategoryName": "Duct Fittings", "BuiltInCategoryId": -1 },
      "NewTool": true,
      "Verify": "CategoryName = Duct Fittings"
    },
    {
      "StepNum": 2,
      "StepName": "add_parameters",
      "Tool": "family.add_parameter_safe",
      "Purpose": "Tao 5 parameters: Large_Diameter, Small_Diameter, Transition_Length, Wall_Thickness, Body_Material.",
      "Repeat": 5,
      "Payloads": [
        { "ParameterName": "Large_Diameter", "ParameterType": "Length", "ParameterGroup": "PG_GEOMETRY", "IsInstance": false, "DefaultValue": "0.5" },
        { "ParameterName": "Small_Diameter", "ParameterType": "Length", "ParameterGroup": "PG_GEOMETRY", "IsInstance": false, "DefaultValue": "0.328" },
        { "ParameterName": "Transition_Length", "ParameterType": "Length", "ParameterGroup": "PG_GEOMETRY", "IsInstance": false, "DefaultValue": "1.0" },
        { "ParameterName": "Wall_Thickness", "ParameterType": "Length", "ParameterGroup": "PG_GEOMETRY", "IsInstance": false, "DefaultValue": "0.003" },
        { "ParameterName": "Body_Material", "ParameterType": "Material", "ParameterGroup": "PG_MATERIALS", "IsInstance": false, "DefaultValue": "" }
      ],
      "Verify": "family.xray shows 5 new parameters"
    },
    {
      "StepNum": 3,
      "StepName": "add_reference_planes",
      "Tool": "family.add_reference_plane_safe",
      "Purpose": "Tao 3 ref planes: Top (Z=1), Bottom (Z=0), Center (Z=0.5).",
      "Repeat": 3,
      "Payloads": [
        { "Name": "Top_Plane", "OriginX": 0, "OriginY": 0, "OriginZ": 1.0, "NormalX": 0, "NormalY": 0, "NormalZ": 1, "ExtentFeet": 2.0 },
        { "Name": "Bottom_Plane", "OriginX": 0, "OriginY": 0, "OriginZ": 0, "NormalX": 0, "NormalY": 0, "NormalZ": 1, "ExtentFeet": 2.0 },
        { "Name": "Center_Plane", "OriginX": 0, "OriginY": 0, "OriginZ": 0.5, "NormalX": 0, "NormalY": 0, "NormalZ": 1, "ExtentFeet": 2.0 }
      ],
      "Verify": "family.list_geometry shows 3 new planes"
    },
    {
      "StepNum": 4,
      "StepName": "create_solid_revolution",
      "Tool": "family.create_revolution_safe",
      "Purpose": "Tao solid tapered cone (outer wall) bang revolution 360 do.",
      "Payload": {
        "Profile": [
          { "X": 0.25, "Y": 0.0 },
          { "X": 0.164, "Y": 1.0 },
          { "X": 0.161, "Y": 1.0 },
          { "X": 0.247, "Y": 0.0 }
        ],
        "StartAngle": 0, "EndAngle": 360,
        "AxisOriginX": 0, "AxisOriginY": 0,
        "AxisDirectionX": 0, "AxisDirectionY": 1,
        "IsVoid": false
      },
      "OutputCapture": "solid_element_id",
      "Verify": "form created, capture ChangedIds[0]"
    },
    {
      "StepNum": 5,
      "StepName": "create_void_revolution",
      "Tool": "family.create_revolution_safe",
      "Purpose": "Tao void interior (khoet rong ben trong ong).",
      "Payload": {
        "Profile": [
          { "X": 0.247, "Y": 0.0 },
          { "X": 0.161, "Y": 1.0 },
          { "X": 0.0, "Y": 1.0 },
          { "X": 0.0, "Y": 0.0 }
        ],
        "StartAngle": 0, "EndAngle": 360,
        "AxisOriginX": 0, "AxisOriginY": 0,
        "AxisDirectionX": 0, "AxisDirectionY": 1,
        "IsVoid": true
      },
      "OutputCapture": "void_element_id",
      "Verify": "void form created"
    },
    {
      "StepNum": 6,
      "StepName": "create_subcategories",
      "Tool": "family.create_subcategory_safe",
      "Purpose": "Tao 3 subcategories: Body, Insulation, Center Line.",
      "NewTool": true,
      "Repeat": 3,
      "Payloads": [
        { "SubcategoryName": "Body", "LineWeight": 3, "LineColorR": 128, "LineColorG": 128, "LineColorB": 128 },
        { "SubcategoryName": "Insulation", "LineWeight": 1, "LineColorR": 255, "LineColorG": 200, "LineColorB": 0 },
        { "SubcategoryName": "Center Line", "LineWeight": 1, "LineColorR": 0, "LineColorG": 180, "LineColorB": 0 }
      ]
    },
    {
      "StepNum": 7,
      "StepName": "set_void_visibility",
      "Tool": "family.set_visibility_safe",
      "Purpose": "An void geometry o Coarse detail level (chi hien Fine/Medium).",
      "NewTool": true,
      "Payload": {
        "FormElementId": "{void_element_id}",
        "IsShownInFine": true, "IsShownInMedium": true, "IsShownInCoarse": false,
        "IsShownInPlanRCP": true, "IsShownInFrontBack": true, "IsShownInLeftRight": true
      }
    },
    {
      "StepNum": 8,
      "StepName": "bind_material",
      "Tool": "family.bind_material_safe",
      "Purpose": "Bind Body_Material parameter vao solid geometry de control appearance.",
      "NewTool": true,
      "Payload": {
        "FormElementId": "{solid_element_id}",
        "MaterialParameterName": "Body_Material",
        "DefaultMaterialName": ""
      }
    },
    {
      "StepNum": 9,
      "StepName": "add_dimensions",
      "Tool": "family.add_dimension_safe",
      "Purpose": "Tao dimension giua ref planes va bind vao Transition_Length parameter.",
      "NewTool": true,
      "Repeat": 2,
      "Payloads": [
        { "ReferencePlane1Name": "Bottom_Plane", "ReferencePlane2Name": "Top_Plane", "LabelParameterName": "Transition_Length", "IsLocked": false, "DimensionType": "linear" },
        { "ReferencePlane1Name": "Bottom_Plane", "ReferencePlane2Name": "Center_Plane", "LabelParameterName": "", "IsLocked": false, "DimensionType": "linear" }
      ]
    },
    {
      "StepNum": 10,
      "StepName": "set_formula",
      "Tool": "family.set_parameter_formula_safe",
      "Purpose": "Wall_Thickness = 1% Large_Diameter (tu dong theo kich thuoc).",
      "Payload": { "ParameterName": "Wall_Thickness", "Formula": "Large_Diameter * 0.01" }
    },
    {
      "StepNum": 11,
      "StepName": "add_connectors",
      "Tool": "family.add_connector_safe",
      "Purpose": "Them 2 duct connectors: dau lon (Supply) va dau nho (Supply).",
      "NewTool": true,
      "Repeat": 2,
      "Payloads": [
        { "ConnectorDomain": "duct", "HostGeometryElementId": "{solid_element_id}", "ConnectorType": "End", "ProfileOption": "Round", "Direction": "NegZ", "DiameterParameterName": "Large_Diameter", "SystemClassification": "Supply" },
        { "ConnectorDomain": "duct", "HostGeometryElementId": "{solid_element_id}", "ConnectorType": "End", "ProfileOption": "Round", "Direction": "Z", "DiameterParameterName": "Small_Diameter", "SystemClassification": "Supply" }
      ]
    },
    {
      "StepNum": 12,
      "StepName": "create_types",
      "Tool": "family.set_type_catalog_safe",
      "Purpose": "Tao 4 standard types: DN100-DN80, DN150-DN100, DN200-DN150, DN250-DN200.",
      "Payload": {
        "Types": [
          { "TypeName": "DN100-DN80",  "ParameterValues": { "Large_Diameter": "0.328", "Small_Diameter": "0.262", "Transition_Length": "0.656" } },
          { "TypeName": "DN150-DN100", "ParameterValues": { "Large_Diameter": "0.492", "Small_Diameter": "0.328", "Transition_Length": "0.820" } },
          { "TypeName": "DN200-DN150", "ParameterValues": { "Large_Diameter": "0.656", "Small_Diameter": "0.492", "Transition_Length": "0.984" } },
          { "TypeName": "DN250-DN200", "ParameterValues": { "Large_Diameter": "0.820", "Small_Diameter": "0.656", "Transition_Length": "1.148" } }
        ],
        "DeleteExistingTypes": false
      }
    },
    {
      "StepNum": 13,
      "StepName": "verify",
      "Tool": "family.list_geometry",
      "Purpose": "Kiem tra ket qua cuoi cung.",
      "Verify": "Forms >= 2, ReferencePlanes >= 3, Parameters >= 5, Types >= 4"
    },
    {
      "StepNum": 14,
      "StepName": "save",
      "Tool": "family.save_safe",
      "Purpose": "Luu family document.",
      "Payload": { "SaveAsPath": "", "OverwriteExisting": true, "CompactFile": false }
    }
  ],
  "ToolsShowcased": {
    "Existing": ["add_parameter_safe", "add_reference_plane_safe", "create_revolution_safe", "set_parameter_formula_safe", "set_type_catalog_safe", "list_geometry", "save_safe"],
    "NewTier1": ["add_dimension_safe", "add_connector_safe"],
    "NewTier2": ["set_visibility_safe", "create_subcategory_safe", "bind_material_safe"],
    "NewTier3": ["set_category_safe"]
  },
  "ExpectedResult": {
    "FamilyName": "(user's family name)",
    "Category": "Duct Fittings",
    "Parameters": 5,
    "ReferencePlanes": 3,
    "GeometryForms": 2,
    "Subcategories": 3,
    "DuctConnectors": 2,
    "Dimensions": 2,
    "Formulas": 1,
    "Types": 4,
    "ToolCallsTotal": 22
  }
}
