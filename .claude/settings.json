{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "description": "Live library docs injection  -  up-to-date, version-specific docs for any library"
    },
    "mem0": {
      "command": "python",
      "args": [
        ".claude/mcp/mem0-server.py"
      ],
      "description": "Persistent AI memory  -  user prefs, project decisions, lessons learned (self-hosted)",
      "env": {
        "MEM0_LLM_PROVIDER": "openai",
        "MEM0_LLM_MODEL": "gpt-4.1-nano"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "description": "Dynamic reasoning chains for complex multi-step BIM analysis and planning"
    },
    "qdrant": {
      "command": "uvx",
      "args": [
        "mcp-server-qdrant"
      ],
      "description": "Vector search for BIM semantic memory  -  search across project knowledge",
      "env": {
        "QDRANT_URL": "http://127.0.0.1:6333",
        "COLLECTION_NAME": "bim765t"
      }
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@github/github-mcp-server"
      ],
      "description": "GitHub API  -  PRs, issues, code search, CI workflows for meococ/765T-Development",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    },
    "sqlite": {
      "command": "uvx",
      "args": [
        "mcp-server-sqlite",
        "--db-path",
        "%APPDATA%/BIM765T/workerhost/workerhost.sqlite"
      ],
      "description": "SQLite database  -  query WorkerHost memory, inspect mission events, debug data"
    },
    "semgrep": {
      "type": "url",
      "url": "https://mcp.semgrep.ai/mcp",
      "description": "Static security analysis  -  scan C# code for vulnerabilities, enforce safety rules"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/security/block-dangerous.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "./.claude/hooks/quality/pre-build-validate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/quality/post-write-csharp-lint.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "./.claude/hooks/quality/architecture-guard.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/quality/stop-quality-gate.sh",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(dotnet *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(powershell -File .\\tools\\* *)",
      "Bash(dir *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(type *)",
      "Bash(echo *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Agent(*)",
      "mcp__context7__*",
      "mcp__mem0__*",
      "mcp__memory__*",
      "mcp__sequential-thinking__*",
      "mcp__qdrant__*",
      "mcp__github__*",
      "mcp__sqlite__*",
      "mcp__semgrep__*"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(rm -rf /*)",
      "Bash(del /s /q C:\\*)"
    ]
  }
}